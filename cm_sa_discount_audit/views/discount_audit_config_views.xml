<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_discount_config_form" model="ir.ui.view">
        <field name="name">cm_sa.discount.audit.config.form</field>
        <field name="model">cm_sa.discount.audit.config</field>
        <field name="arch" type="xml">
            <form string="Discount Audit Settings">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="threshold_pct"/>
                        <field name="show_reason_field"/>
                        <field name="post_chatter_on_audit"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        Every SO line whose discount strictly exceeds the
                        threshold writes one row to the audit log at
                        create / write time. No approval workflow, no
                        blocking — just the receipts.
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_discount_config_list" model="ir.ui.view">
        <field name="name">cm_sa.discount.audit.config.list</field>
        <field name="model">cm_sa.discount.audit.config</field>
        <field name="arch" type="xml">
            <list string="Discount Audit Settings" create="false">
                <field name="name"/>
                <field name="threshold_pct"/>
                <field name="show_reason_field"/>
                <field name="post_chatter_on_audit"/>
            </list>
        </field>
    </record>

    <record id="action_discount_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">cm_sa.discount.audit.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
