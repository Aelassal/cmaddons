<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_att_size_rule_list" model="ir.ui.view">
        <field name="name">cm_sa.attachment.size.rule.list</field>
        <field name="model">cm_sa.attachment.size.rule</field>
        <field name="arch" type="xml">
            <list string="Attachment Size Rules">
                <field name="name"/>
                <field name="model_id"/>
                <field name="max_mb"/>
                <field name="bypass_group_id"/>
                <field name="log_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_att_size_rule_form" model="ir.ui.view">
        <field name="name">cm_sa.attachment.size.rule.form</field>
        <field name="model">cm_sa.attachment.size.rule</field>
        <field name="arch" type="xml">
            <form string="Attachment Size Rule">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs" type="object"
                                class="oe_stat_button" icon="fa-history">
                            <field name="log_count" widget="statinfo" string="Bypasses"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Sale Order attachments ≤ 25 MB"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_id"/>
                            <field name="model_name" invisible="1"/>
                            <field name="max_mb"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="bypass_group_id"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Error Message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_att_size_rule" model="ir.actions.act_window">
        <field name="name">Size Rules</field>
        <field name="res_model">cm_sa.attachment.size.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first size rule</p>
            <p>Pick a model + max MB. Uploads over the cap raise a UserError.</p>
        </field>
    </record>
</odoo>
