<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_run_quotation_chase" model="ir.cron">
        <field name="name">Quotation Chase: send due chases</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="state">code</field>
        <field name="code">model._cron_run_quotation_chase()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>

    <record id="action_cron_run_quotation_chase" model="ir.actions.act_window">
        <field name="name">Run Chase Now</field>
        <field name="res_model">ir.cron</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="cron_run_quotation_chase"/>
    </record>
</odoo>
