<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chase_schedule_tree" model="ir.ui.view">
        <field name="name">cm_sa.chase.schedule.list</field>
        <field name="model">cm_sa.chase.schedule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="step_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_chase_schedule_form" model="ir.ui.view">
        <field name="name">cm_sa.chase.schedule.form</field>
        <field name="model">cm_sa.chase.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Standard 3-7-14"/></h1>
                    </div>
                    <group>
                        <field name="active" invisible="1"/>
                        <field name="description" placeholder="Internal notes about this schedule..."/>
                    </group>
                    <notebook>
                        <page string="Chase Steps">
                            <field name="step_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="days_after_send"/>
                                    <field name="mail_template_id" options="{'no_create': True}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_chase_schedule" model="ir.actions.act_window">
        <field name="name">Quotation Chase Schedules</field>
        <field name="res_model">cm_sa.chase.schedule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first chase schedule</p>
            <p>Define how many follow-up emails to send and how many days between each.
               Then pick the schedule on a quotation to start chasing.</p>
        </field>
    </record>
</odoo>
