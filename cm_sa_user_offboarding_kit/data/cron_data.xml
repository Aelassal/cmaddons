<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_auto_deactivate_scheduled" model="ir.cron">
        <field name="name">User Offboarding: archive scheduled deactivations</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_deactivate_scheduled()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_flag_dormant_users" model="ir.cron">
        <field name="name">User Offboarding: scan dormant users</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">model._cron_flag_dormant_users()</field>
        <field name="interval_number">7</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
