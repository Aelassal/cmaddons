<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_activity_reassign_wizard_form" model="ir.ui.view">
        <field name="name">cm_sa.activity.reassign.wizard.form</field>
        <field name="model">cm_sa.activity.reassign.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Reassign Activities">
                <sheet>
                    <div class="oe_title">
                        <h1>Bulk Reassign Activities</h1>
                        <p class="text-muted">
                            Pick the source and target users, optionally narrow the
                            scope with the filters below, then press
                            <b>Refresh count</b> to preview, and <b>Apply</b> to commit.
                        </p>
                    </div>
                    <group>
                        <group string="Users">
                            <field name="from_user_id"/>
                            <field name="to_user_id"/>
                        </group>
                        <group string="Reschedule (optional)">
                            <field name="new_deadline"/>
                        </group>
                    </group>
                    <group string="Filters (optional)">
                        <group>
                            <field name="model_id"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="activity_type_id"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="overdue_only"/>
                            <field name="date_deadline_from" invisible="overdue_only"/>
                            <field name="date_deadline_to" invisible="overdue_only"/>
                        </group>
                    </group>
                    <group string="Preview">
                        <field name="count_to_reassign" readonly="1"/>
                        <field name="preview_text" nolabel="1" colspan="2" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_refresh_count" type="object"
                            string="Refresh count" class="btn-secondary"/>
                    <button name="action_reassign" type="object"
                            string="Apply" class="btn-primary"
                            confirm="Reassign every matching activity to the target user?"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_activity_reassign_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Reassign Activities</field>
        <field name="res_model">cm_sa.activity.reassign.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
