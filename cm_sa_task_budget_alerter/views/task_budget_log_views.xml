<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_budget_log_list" model="ir.ui.view">
        <field name="name">cm_sa.task.budget.alert.log.list</field>
        <field name="model">cm_sa.task.budget.alert.log</field>
        <field name="arch" type="xml">
            <list string="Task Budget Alert Log" create="false">
                <field name="create_date" string="When"/>
                <field name="task_id"/>
                <field name="project_id"/>
                <field name="threshold_pct"/>
                <field name="percent_at_alert"/>
                <field name="planned_hours"/>
                <field name="effective_hours"/>
                <field name="rule_id"/>
            </list>
        </field>
    </record>

    <record id="view_task_budget_log_form" model="ir.ui.view">
        <field name="name">cm_sa.task.budget.alert.log.form</field>
        <field name="model">cm_sa.task.budget.alert.log</field>
        <field name="arch" type="xml">
            <form string="Task Budget Alert" create="false" edit="false">
                <header>
                    <button name="action_open_task" type="object"
                            string="Open Task" class="btn-primary"
                            invisible="not task_id"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" string="When"/>
                            <field name="rule_id"/>
                            <field name="threshold_pct"/>
                            <field name="percent_at_alert"/>
                        </group>
                        <group>
                            <field name="task_id"/>
                            <field name="project_id"/>
                            <field name="planned_hours"/>
                            <field name="effective_hours"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_task_budget_log_search" model="ir.ui.view">
        <field name="name">cm_sa.task.budget.alert.log.search</field>
        <field name="model">cm_sa.task.budget.alert.log</field>
        <field name="arch" type="xml">
            <search string="Task Budget Alert Log">
                <field name="task_id"/>
                <field name="project_id"/>
                <field name="rule_id"/>
                <filter name="t75" string="75%" domain="[('threshold_pct', '=', 75)]"/>
                <filter name="t90" string="90%" domain="[('threshold_pct', '=', 90)]"/>
                <filter name="t100" string="100%+" domain="[('threshold_pct', '&gt;=', 100)]"/>
                <group>
                    <filter name="group_project" string="Project"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_threshold" string="Threshold"
                            context="{'group_by': 'threshold_pct'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_task_budget_log" model="ir.actions.act_window">
        <field name="name">Alert Log</field>
        <field name="res_model">cm_sa.task.budget.alert.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
