<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_budget_rule_list" model="ir.ui.view">
        <field name="name">cm_sa.task.budget.rule.list</field>
        <field name="model">cm_sa.task.budget.rule</field>
        <field name="arch" type="xml">
            <list string="Task Budget Rules">
                <field name="name"/>
                <field name="thresholds_csv"/>
                <field name="min_planned_hours"/>
                <field name="notify_assignee"/>
                <field name="notify_manager"/>
                <field name="log_count"/>
                <field name="last_run"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_task_budget_rule_form" model="ir.ui.view">
        <field name="name">cm_sa.task.budget.rule.form</field>
        <field name="model">cm_sa.task.budget.rule</field>
        <field name="arch" type="xml">
            <form string="Task Budget Rule">
                <header>
                    <button name="action_run_now" type="object"
                            string="Run Now" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs" type="object"
                                class="oe_stat_button" icon="fa-history">
                            <field name="log_count" widget="statinfo"
                                   string="Alerts"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Services team — 75/90/100"/></h1>
                    </div>
                    <group>
                        <group string="Thresholds">
                            <field name="thresholds_csv"/>
                            <field name="min_planned_hours"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Notify">
                            <field name="notify_assignee"/>
                            <field name="notify_manager"/>
                            <field name="extra_notify_user_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group string="Scope">
                            <field name="project_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="exclude_stage_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Status">
                            <field name="last_run" readonly="1"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        Hourly cron <b>Task Budget Alerter: hourly scan</b>
                        runs automatically. Each (task, threshold) pair
                        alerts exactly once — the log is the dedupe source.
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_task_budget_rule_search" model="ir.ui.view">
        <field name="name">cm_sa.task.budget.rule.search</field>
        <field name="model">cm_sa.task.budget.rule</field>
        <field name="arch" type="xml">
            <search string="Task Budget Rules">
                <field name="name"/>
                <filter name="active" string="Active"
                        domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Archived"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_task_budget_rule" model="ir.actions.act_window">
        <field name="name">Task Budget Rules</field>
        <field name="res_model">cm_sa.task.budget.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first budget rule</p>
            <p>Set thresholds (e.g. 75,90,100), pick projects, pick recipients. Hourly cron handles the rest.</p>
        </field>
    </record>
</odoo>
