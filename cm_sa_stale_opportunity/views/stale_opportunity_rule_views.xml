<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stale_opp_rule_list" model="ir.ui.view">
        <field name="name">cm_sa.stale.opportunity.rule.list</field>
        <field name="model">cm_sa.stale.opportunity.rule</field>
        <field name="arch" type="xml">
            <list string="Stale Opportunity Rules">
                <field name="name"/>
                <field name="stale_days"/>
                <field name="warning_days"/>
                <field name="stale_reference"/>
                <field name="lost_reason_id"/>
                <field name="log_count"/>
                <field name="last_run"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_stale_opp_rule_form" model="ir.ui.view">
        <field name="name">cm_sa.stale.opportunity.rule.form</field>
        <field name="model">cm_sa.stale.opportunity.rule</field>
        <field name="arch" type="xml">
            <form string="Stale Opportunity Rule">
                <header>
                    <button name="action_run_now" type="object"
                            string="Run Now" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs" type="object"
                                class="oe_stat_button" icon="fa-history">
                            <field name="log_count" widget="statinfo"
                                   string="Events"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Close opps untouched for 45 days"/></h1>
                    </div>
                    <group>
                        <group string="Staleness Thresholds">
                            <field name="stale_days"/>
                            <field name="warning_days"/>
                            <field name="stale_reference"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Scope">
                            <field name="stage_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="team_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="extra_domain" widget="char_domain"/>
                        </group>
                    </group>
                    <group>
                        <group string="On Close">
                            <field name="lost_reason_id"
                                   options="{'no_create': True}"/>
                            <field name="notify_owner_on_close"/>
                        </group>
                        <group string="Warning">
                            <field name="notify_owner_on_warning"/>
                        </group>
                    </group>
                    <group string="Status">
                        <field name="last_run" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_stale_opp_rule_search" model="ir.ui.view">
        <field name="name">cm_sa.stale.opportunity.rule.search</field>
        <field name="model">cm_sa.stale.opportunity.rule</field>
        <field name="arch" type="xml">
            <search string="Stale Opportunity Rules">
                <field name="name"/>
                <field name="lost_reason_id"/>
                <filter name="active" string="Active"
                        domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Archived"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_stale_opp_rule" model="ir.actions.act_window">
        <field name="name">Stale Opportunity Rules</field>
        <field name="res_model">cm_sa.stale.opportunity.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first stale-opp rule</p>
            <p>Set stale days, warning days, pick a lost reason. Cron runs daily.</p>
        </field>
    </record>
</odoo>
