<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_dedup" model="ir.ui.view">
        <field name="name">account.move.form.dedup</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning mb-0"
                     role="alert"
                     invisible="not dedup_has_warning"
                     style="border-radius:0;">
                    <strong>Possible duplicate vendor bill.</strong>
                    <field name="dedup_warning" readonly="1" nolabel="1"/>
                    <button type="object" name="action_view_dedup_candidates"
                            string="View candidates"
                            class="btn btn-sm btn-link"
                            invisible="not dedup_has_warning"/>
                    <button type="object" name="action_log_dedup_review"
                            string="Open review"
                            class="btn btn-sm btn-link"
                            invisible="not dedup_has_warning"/>
                </div>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <group invisible="1">
                    <field name="dedup_score"/>
                    <field name="dedup_has_warning"/>
                    <field name="dedup_candidate_ids"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
