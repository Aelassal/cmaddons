<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reset_audit_wizard_form" model="ir.ui.view">
        <field name="name">cm_sa.reset_audit.wizard.form</field>
        <field name="model">cm_sa.reset_audit.wizard</field>
        <field name="arch" type="xml">
            <form string="Reason for Reset">
                <sheet>
                    <div class="alert alert-warning" role="alert"
                         style="margin-bottom:14px;">
                        You are about to reset the following record(s) back to
                        draft. An audit log entry will be created.
                    </div>
                    <group>
                        <field name="model_name" readonly="1"/>
                        <field name="method_name" invisible="1"/>
                        <field name="records_preview" readonly="1"/>
                        <field name="rule_id" invisible="1"/>
                        <field name="record_id_str" invisible="1"/>
                        <field name="min_length" invisible="1"/>
                    </group>
                    <group string="Reason for reset">
                        <field name="reason" nolabel="1" placeholder="Required. Explain why this record is being reset to draft."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_reset" type="object"
                            string="Confirm Reset" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
