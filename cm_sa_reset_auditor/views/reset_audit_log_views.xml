<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reset_audit_log_list" model="ir.ui.view">
        <field name="name">cm_sa.reset_audit.log.list</field>
        <field name="model">cm_sa.reset_audit.log</field>
        <field name="arch" type="xml">
            <list string="Reset Audit Log" create="false">
                <field name="create_date" string="When"/>
                <field name="user_id" string="By"/>
                <field name="rule_id"/>
                <field name="res_model" string="Model"/>
                <field name="record_name" string="Record"/>
                <field name="method_name"/>
                <field name="reason"/>
            </list>
        </field>
    </record>

    <record id="view_reset_audit_log_form" model="ir.ui.view">
        <field name="name">cm_sa.reset_audit.log.form</field>
        <field name="model">cm_sa.reset_audit.log</field>
        <field name="arch" type="xml">
            <form string="Reset Audit Log" create="false" edit="false">
                <header>
                    <button name="action_open_source" type="object"
                            string="Open Record" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" string="When"/>
                            <field name="user_id" string="Reset by"/>
                            <field name="rule_id"/>
                        </group>
                        <group>
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="record_name"/>
                            <field name="method_name"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_reset_audit_log_search" model="ir.ui.view">
        <field name="name">cm_sa.reset_audit.log.search</field>
        <field name="model">cm_sa.reset_audit.log</field>
        <field name="arch" type="xml">
            <search string="Reset Audit Log">
                <field name="user_id"/>
                <field name="res_model"/>
                <field name="record_name"/>
                <field name="reason"/>
                <filter name="filter_today" string="Today"
                        domain="[('create_date', '&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_7d" string="Last 7 days"
                        domain="[('create_date', '&gt;=',
                                  (context_today() + datetime.timedelta(days=-7))
                                  .strftime('%Y-%m-%d'))]"/>
                <filter name="filter_30d" string="Last 30 days"
                        domain="[('create_date', '&gt;=',
                                  (context_today() + datetime.timedelta(days=-30))
                                  .strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter name="group_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_model" string="Model"
                            context="{'group_by': 'res_model'}"/>
                    <filter name="group_rule" string="Rule"
                            context="{'group_by': 'rule_id'}"/>
                    <filter name="group_week" string="Week"
                            context="{'group_by': 'create_date:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_reset_audit_log_pivot" model="ir.ui.view">
        <field name="name">cm_sa.reset_audit.log.pivot</field>
        <field name="model">cm_sa.reset_audit.log</field>
        <field name="arch" type="xml">
            <pivot string="Reset Audit Log">
                <field name="user_id" type="row"/>
                <field name="res_model" type="col"/>
                <field name="create_date" interval="week" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="action_reset_audit_log" model="ir.actions.act_window">
        <field name="name">Reset Audit Log</field>
        <field name="res_model">cm_sa.reset_audit.log</field>
        <field name="view_mode">list,pivot,form</field>
    </record>
</odoo>
