<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reset_audit_rule_list" model="ir.ui.view">
        <field name="name">cm_sa.reset_audit.rule.list</field>
        <field name="model">cm_sa.reset_audit.rule</field>
        <field name="arch" type="xml">
            <list string="Reset-to-Draft Rules">
                <field name="name"/>
                <field name="model_name"/>
                <field name="method_name"/>
                <field name="require_reason"/>
                <field name="required_group_id"/>
                <field name="log_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_reset_audit_rule_form" model="ir.ui.view">
        <field name="name">cm_sa.reset_audit.rule.form</field>
        <field name="model">cm_sa.reset_audit.rule</field>
        <field name="arch" type="xml">
            <form string="Reset-to-Draft Rule">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs" type="object"
                                class="oe_stat_button" icon="fa-history">
                            <field name="log_count" widget="statinfo"
                                   string="Logs"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. SO reset audit"/></h1>
                    </div>
                    <group>
                        <group string="Target">
                            <field name="model_id"/>
                            <field name="method_name"/>
                            <field name="domain" widget="char_domain"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Policy">
                            <field name="require_reason"/>
                            <field name="min_reason_length"
                                   invisible="not require_reason"/>
                            <field name="required_group_id"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_reset_audit_rule_search" model="ir.ui.view">
        <field name="name">cm_sa.reset_audit.rule.search</field>
        <field name="model">cm_sa.reset_audit.rule</field>
        <field name="arch" type="xml">
            <search string="Reset Audit Rules">
                <field name="name"/>
                <field name="model_name"/>
                <field name="method_name"/>
                <filter name="active" string="Active"
                        domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Archived"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter name="group_model" string="Model"
                            context="{'group_by': 'model_name'}"/>
                    <filter name="group_method" string="Method"
                            context="{'group_by': 'method_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_reset_audit_rule" model="ir.actions.act_window">
        <field name="name">Reset Rules</field>
        <field name="res_model">cm_sa.reset_audit.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first reset-to-draft rule</p>
            <p>Pick a model and a reset method. Every future reset will prompt
               for a reason and land in the audit log.</p>
        </field>
    </record>
</odoo>
