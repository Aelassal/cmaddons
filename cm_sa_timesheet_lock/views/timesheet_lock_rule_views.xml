<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ts_lock_rule_list" model="ir.ui.view">
        <field name="name">cm_sa.timesheet.lock.rule.list</field>
        <field name="model">cm_sa.timesheet.lock.rule</field>
        <field name="arch" type="xml">
            <list string="Timesheet Lock Rules">
                <field name="name"/>
                <field name="max_days_back"/>
                <field name="bypass_group_id"/>
                <field name="log_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_ts_lock_rule_form" model="ir.ui.view">
        <field name="name">cm_sa.timesheet.lock.rule.form</field>
        <field name="model">cm_sa.timesheet.lock.rule</field>
        <field name="arch" type="xml">
            <form string="Timesheet Lock Rule">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs" type="object"
                                class="oe_stat_button" icon="fa-history">
                            <field name="log_count" widget="statinfo" string="Bypasses"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Consultants — 14-day rolling window"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="max_days_back"/>
                            <field name="applies_to_group_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="bypass_group_id"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Error Message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        The window is a <b>rolling</b> N days — today minus
                        N. It self-advances every day. No admin calendar
                        ceremony. Admins not in any applies-to group are
                        never restricted.
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_ts_lock_rule" model="ir.actions.act_window">
        <field name="name">Lock Rules</field>
        <field name="res_model">cm_sa.timesheet.lock.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
