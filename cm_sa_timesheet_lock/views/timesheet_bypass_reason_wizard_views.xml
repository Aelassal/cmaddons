<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_timesheet_bypass_reason_wizard_form" model="ir.ui.view">
        <field name="name">cm_sa.timesheet.lock.bypass.wizard.form</field>
        <field name="model">cm_sa.timesheet.lock.bypass.wizard</field>
        <field name="arch" type="xml">
            <form string="Enter Bypass Reason">
                <group>
                    <field name="line_ids" widget="many2many_tags" readonly="1"/>
                    <field name="reason" placeholder="Example: Approved correction by project manager."/>
                </group>
                <footer>
                    <button name="action_apply_reason"
                            type="object"
                            string="Apply Reason"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
