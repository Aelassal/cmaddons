<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_score_config_list" model="ir.ui.view">
        <field name="name">cm_sa.payment_score.config.list</field>
        <field name="model">cm_sa.payment_score.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="window_days"/>
                <field name="band_a_min"/>
                <field name="band_b_min"/>
                <field name="band_c_min"/>
                <field name="require_rule"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_payment_score_config_form" model="ir.ui.view">
        <field name="name">cm_sa.payment_score.config.form</field>
        <field name="model">cm_sa.payment_score.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Scoring Window">
                            <field name="window_days"/>
                            <field name="active"/>
                        </group>
                        <group string="Optional Block">
                            <field name="require_rule"/>
                        </group>
                    </group>
                    <group string="Metric Weights (relative — do not need to sum to 100)">
                        <group>
                            <field name="weight_days_late"/>
                            <field name="weight_partial"/>
                        </group>
                        <group>
                            <field name="weight_stretch"/>
                            <field name="weight_on_time"/>
                        </group>
                    </group>
                    <group string="Band Cutoffs">
                        <group>
                            <field name="band_a_min"/>
                            <field name="band_b_min"/>
                        </group>
                        <group>
                            <field name="band_c_min"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>How it works.</strong> A nightly cron scans
                        every customer with posted invoices in the window.
                        Each metric yields 0-100 points; the weighted average
                        becomes the score and maps to a band. Turn on
                        <b>Block D-band sale orders</b> to stop confirms for
                        the worst payers (admins bypass).
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_payment_score_config" model="ir.actions.act_window">
        <field name="name">Payment Score Settings</field>
        <field name="res_model">cm_sa.payment_score.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
