<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_score_snapshot_list" model="ir.ui.view">
        <field name="name">cm_sa.payment_score.snapshot.list</field>
        <field name="model">cm_sa.payment_score.snapshot</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="computed_at"/>
                <field name="partner_id"/>
                <field name="period_year"/>
                <field name="period_month"/>
                <field name="score"/>
                <field name="band" widget="badge"
                       decoration-success="band == 'A'"
                       decoration-info="band == 'B'"
                       decoration-warning="band == 'C'"
                       decoration-danger="band == 'D'"/>
            </list>
        </field>
    </record>

    <record id="view_payment_score_snapshot_form" model="ir.ui.view">
        <field name="name">cm_sa.payment_score.snapshot.form</field>
        <field name="model">cm_sa.payment_score.snapshot</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="computed_at"/>
                        </group>
                        <group>
                            <field name="score"/>
                            <field name="band"/>
                            <field name="period_year"/>
                            <field name="period_month"/>
                        </group>
                    </group>
                    <group string="Breakdown (JSON)">
                        <field name="breakdown_json" nolabel="1" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_payment_score_snapshot_search" model="ir.ui.view">
        <field name="name">cm_sa.payment_score.snapshot.search</field>
        <field name="model">cm_sa.payment_score.snapshot</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="period_year"/>
                <field name="period_month"/>
                <filter name="filter_a" string="Band A"
                        domain="[('band', '=', 'A')]"/>
                <filter name="filter_b" string="Band B"
                        domain="[('band', '=', 'B')]"/>
                <filter name="filter_c" string="Band C"
                        domain="[('band', '=', 'C')]"/>
                <filter name="filter_d" string="Band D"
                        domain="[('band', '=', 'D')]"/>
                <group>
                    <filter name="group_partner" string="Partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_band" string="Band"
                            context="{'group_by': 'band'}"/>
                    <filter name="group_year" string="Year"
                            context="{'group_by': 'period_year'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_payment_score_snapshot" model="ir.actions.act_window">
        <field name="name">Payment Score History</field>
        <field name="res_model">cm_sa.payment_score.snapshot</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
