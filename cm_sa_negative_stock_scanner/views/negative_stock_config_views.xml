<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_negstock_config_form" model="ir.ui.view">
        <field name="name">cm_sa.negative.stock.config.form</field>
        <field name="model">cm_sa.negative.stock.config</field>
        <field name="arch" type="xml">
            <form string="Negative Stock Configuration">
                <header>
                    <button name="action_scan_now" type="object"
                            string="Scan Now" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_snapshots" type="object"
                                class="oe_stat_button" icon="fa-history">
                            <field name="snapshot_count" widget="statinfo"
                                   string="Snapshots"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Scan Scope">
                            <field name="include_internal_only"/>
                            <field name="min_days_negative"/>
                            <field name="extra_domain" widget="char_domain"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Digest">
                            <field name="notify_user_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        The weekly cron <b>Negative Inventory Scanner: weekly
                        scan</b> runs this scan automatically. Use
                        <b>Scan Now</b> for an immediate run; results are
                        stored as snapshots and emailed to the notify group.
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_negstock_config_list" model="ir.ui.view">
        <field name="name">cm_sa.negative.stock.config.list</field>
        <field name="model">cm_sa.negative.stock.config</field>
        <field name="arch" type="xml">
            <list string="Negative Stock Config" create="false">
                <field name="name"/>
                <field name="min_days_negative"/>
                <field name="include_internal_only"/>
                <field name="snapshot_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_negstock_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">cm_sa.negative.stock.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
