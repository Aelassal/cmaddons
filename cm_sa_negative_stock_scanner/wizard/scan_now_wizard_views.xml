<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_scan_now_wizard_form" model="ir.ui.view">
        <field name="name">cm_sa.negative.stock.scan_now.wizard.form</field>
        <field name="model">cm_sa.negative.stock.scan_now.wizard</field>
        <field name="arch" type="xml">
            <form string="Scan Negative Stock">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Triggers an immediate negative-stock scan using the
                        selected configuration. Result opens as a new
                        snapshot.
                    </div>
                    <group>
                        <field name="config_id"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_run" type="object"
                            string="Run Scan Now" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_scan_now_wizard" model="ir.actions.act_window">
        <field name="name">Scan Now</field>
        <field name="res_model">cm_sa.negative.stock.scan_now.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
