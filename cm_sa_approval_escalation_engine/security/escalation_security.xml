<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_escalation" model="res.groups.privilege">
        <field name="name">Approval Escalation</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_escalation_manager" model="res.groups">
        <field name="name">Escalation Administrator</field>
        <field name="privilege_id" ref="privilege_escalation"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
