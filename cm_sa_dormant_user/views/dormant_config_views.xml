<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dormant_config_form" model="ir.ui.view">
        <field name="name">cm_sa.dormant.config.form</field>
        <field name="model">cm_sa.dormant.config</field>
        <field name="arch" type="xml">
            <form string="Dormant User Settings">
                <header>
                    <button name="action_run_now" type="object"
                            string="Run Now" class="btn-primary"/>
                    <button name="action_view_logs" type="object"
                            string="Open Log" class="btn-secondary"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Disabled"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Policy">
                            <field name="inactivity_days"/>
                            <field name="warning_days"/>
                            <field name="auto_archive"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Protection &amp; Notifications">
                            <field name="exclude_group_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="notify_group_id"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="ROI — This Month">
                        <group>
                            <field name="license_rate_usd"/>
                            <field name="warned_this_month" readonly="1"/>
                            <field name="archived_this_month" readonly="1"/>
                        </group>
                        <group>
                            <label for="estimated_savings_usd"
                                   string="Estimated Savings"/>
                            <div>
                                <b>$<field name="estimated_savings_usd"
                                           readonly="1" nolabel="1"/></b>
                                <span class="text-muted">
                                    = archived this month × license rate
                                </span>
                            </div>
                            <field name="last_run" readonly="1"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        The daily cron <b>Dormant User: daily scan</b>
                        handles everything automatically. This form is for
                        tuning the policy and seeing the license-savings
                        ROI at a glance.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dormant_config_list" model="ir.ui.view">
        <field name="name">cm_sa.dormant.config.list</field>
        <field name="model">cm_sa.dormant.config</field>
        <field name="arch" type="xml">
            <list string="Dormant User Settings" create="false">
                <field name="name"/>
                <field name="inactivity_days"/>
                <field name="warning_days"/>
                <field name="auto_archive"/>
                <field name="archived_this_month"/>
                <field name="estimated_savings_usd"/>
                <field name="last_run"/>
            </list>
        </field>
    </record>

    <record id="action_dormant_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">cm_sa.dormant.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
