<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_margin_guard" model="ir.module.category">
        <field name="name">Margin Guard</field>
        <field name="sequence">85</field>
    </record>

    <record id="privilege_margin_guard_administration" model="res.groups.privilege">
        <field name="name">Margin Guard</field>
        <field name="description">Create and maintain company Margin Guard rules.</field>
        <field name="placeholder">No rule administration</field>
        <field name="category_id" ref="module_category_margin_guard"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_margin_guard_rule_admin" model="res.groups">
        <field name="name">Rule Administrator</field>
        <field name="privilege_id" ref="privilege_margin_guard_administration"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Technical users allowed to create and maintain Margin Guard rules without receiving Sales Manager access.</field>
    </record>
</odoo>
