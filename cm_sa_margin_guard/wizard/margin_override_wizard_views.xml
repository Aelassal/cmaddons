<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_margin_override_wizard_form" model="ir.ui.view">
        <field name="name">cm_sa.margin.override.wizard.form</field>
        <field name="model">cm_sa.margin.override.wizard</field>
        <field name="arch" type="xml">
            <form string="Margin Override">
                <sheet>
                    <div class="alert alert-warning" role="alert" style="margin-bottom:14px;">
                        <b>Below-threshold confirmation.</b>
                        Only the selected records listed below require an override reason. Records that comply with the rules are processed normally.
                    </div>
                    <group>
                        <field name="model_name" readonly="1"/>
                        <field name="method_name" invisible="1"/>
                        <field name="record_id_str" invisible="1"/>
                        <field name="rule_id" invisible="1"/>
                        <field name="min_length" invisible="1"/>
                        <field name="records_preview" readonly="1"/>
                    </group>
                    <group string="Detected Margin Violations">
                        <field name="violation_summary" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Already Processed Normally" invisible="not processed_summary">
                        <field name="processed_summary" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Not Processed - No Override Permission" invisible="not blocked_summary">
                        <field name="blocked_summary" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Reason for Override">
                        <field name="reason" nolabel="1" placeholder="Required. Explain why these below-margin records may be confirmed."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_override" type="object"
                            string="Confirm Override" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
