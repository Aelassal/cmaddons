<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attach_log_list" model="ir.ui.view">
        <field name="name">cm_sa.attachment.bypass.log.list</field>
        <field name="model">cm_sa.attachment.bypass.log</field>
        <field name="arch" type="xml">
            <list string="Attachment Bypass Log" create="false">
                <field name="create_date" string="When"/>
                <field name="user_id" string="By"/>
                <field name="rule_id"/>
                <field name="move_id"/>
                <field name="attachment_count_at_bypass"/>
                <field name="reason"/>
            </list>
        </field>
    </record>

    <record id="view_attach_log_form" model="ir.ui.view">
        <field name="name">cm_sa.attachment.bypass.log.form</field>
        <field name="model">cm_sa.attachment.bypass.log</field>
        <field name="arch" type="xml">
            <form string="Bypass Log" create="false" edit="false">
                <header>
                    <button name="action_open_move" type="object"
                            string="Open Move" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" string="When"/>
                            <field name="user_id"/>
                            <field name="rule_id"/>
                        </group>
                        <group>
                            <field name="move_id"/>
                            <field name="attachment_count_at_bypass"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_attach_log_search" model="ir.ui.view">
        <field name="name">cm_sa.attachment.bypass.log.search</field>
        <field name="model">cm_sa.attachment.bypass.log</field>
        <field name="arch" type="xml">
            <search string="Bypass Log">
                <field name="user_id"/>
                <field name="rule_id"/>
                <field name="move_id"/>
                <field name="reason"/>
                <group>
                    <filter name="group_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_rule" string="Rule"
                            context="{'group_by': 'rule_id'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_attach_log" model="ir.actions.act_window">
        <field name="name">Bypass Log</field>
        <field name="res_model">cm_sa.attachment.bypass.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
