<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attach_bypass_wizard_form" model="ir.ui.view">
        <field name="name">cm_sa.attachment.bypass.wizard.form</field>
        <field name="model">cm_sa.attachment.bypass.wizard</field>
        <field name="arch" type="xml">
            <form string="Attachment Bypass">
                <sheet>
                    <div class="alert alert-warning" role="alert"
                         style="margin-bottom:14px;">
                        You are about to post a move that does not meet the
                        attachment requirement. A bypass entry will be logged
                        with your user and reason.
                    </div>
                    <group>
                        <field name="rule_id" invisible="1"/>
                        <field name="move_id_str" invisible="1"/>
                        <field name="min_length" invisible="1"/>
                        <field name="moves_preview" readonly="1"/>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"
                               placeholder="Required. Why are you posting without the required attachment?"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_bypass" type="object"
                            string="Confirm Bypass &amp; Post" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
