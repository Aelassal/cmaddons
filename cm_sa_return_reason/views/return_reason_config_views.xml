<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_return_config_form" model="ir.ui.view">
        <field name="name">cm_sa.return.reason.config.form</field>
        <field name="model">cm_sa.return.reason.config</field>
        <field name="arch" type="xml">
            <form string="Return Reason Settings">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="min_reason_length"/>
                        <field name="require_category"/>
                        <field name="post_chatter_note"/>
                        <field name="active" invisible="1"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        When a user opens the <b>Return</b> wizard on a
                        delivered picking, the form will require a typed
                        reason (and optionally a category). Each return is
                        logged with a per-product breakdown for pivot
                        analytics.
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_return_config_list" model="ir.ui.view">
        <field name="name">cm_sa.return.reason.config.list</field>
        <field name="model">cm_sa.return.reason.config</field>
        <field name="arch" type="xml">
            <list string="Return Reason Settings" create="false">
                <field name="name"/>
                <field name="min_reason_length"/>
                <field name="require_category"/>
                <field name="post_chatter_note"/>
            </list>
        </field>
    </record>
    <record id="action_return_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">cm_sa.return.reason.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
