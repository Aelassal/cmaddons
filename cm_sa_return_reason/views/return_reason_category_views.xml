<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_return_cat_list" model="ir.ui.view">
        <field name="name">cm_sa.return.reason.category.list</field>
        <field name="model">cm_sa.return.reason.category</field>
        <field name="arch" type="xml">
            <list string="Return Reason Categories" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="color" widget="color_picker" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_return_cat" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">cm_sa.return.reason.category</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
