<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_return_log_list" model="ir.ui.view">
        <field name="name">cm_sa.return.reason.log.list</field>
        <field name="model">cm_sa.return.reason.log</field>
        <field name="arch" type="xml">
            <list string="Return Reason Log" create="false">
                <field name="create_date" string="When"/>
                <field name="source_picking_id"/>
                <field name="return_picking_id"/>
                <field name="partner_id"/>
                <field name="category_id"/>
                <field name="reason"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>
    <record id="view_return_log_form" model="ir.ui.view">
        <field name="name">cm_sa.return.reason.log.form</field>
        <field name="model">cm_sa.return.reason.log</field>
        <field name="arch" type="xml">
            <form string="Return Reason Log" create="false" edit="false">
                <header>
                    <button name="action_open_source" type="object"
                            string="Open Source Picking" class="btn-primary"
                            invisible="not source_picking_id"/>
                    <button name="action_open_return" type="object"
                            string="Open Return Picking" class="btn-secondary"
                            invisible="not return_picking_id"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" string="When"/>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="source_picking_id"/>
                            <field name="return_picking_id"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="line_ids">
                                <list create="false" edit="false">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_return_log_search" model="ir.ui.view">
        <field name="name">cm_sa.return.reason.log.search</field>
        <field name="model">cm_sa.return.reason.log</field>
        <field name="arch" type="xml">
            <search string="Return Reason Log">
                <field name="source_picking_id"/>
                <field name="partner_id"/>
                <field name="category_id"/>
                <field name="reason"/>
                <field name="user_id"/>
                <group>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_partner" string="Customer"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="view_return_logline_pivot" model="ir.ui.view">
        <field name="name">cm_sa.return.reason.log.line.pivot</field>
        <field name="model">cm_sa.return.reason.log.line</field>
        <field name="arch" type="xml">
            <pivot string="Returns: Reason × Product">
                <field name="category_id" type="row"/>
                <field name="product_id" type="col"/>
                <field name="qty" type="measure"/>
            </pivot>
        </field>
    </record>
    <record id="view_return_logline_graph" model="ir.ui.view">
        <field name="name">cm_sa.return.reason.log.line.graph</field>
        <field name="model">cm_sa.return.reason.log.line</field>
        <field name="arch" type="xml">
            <graph string="Returns by Category">
                <field name="category_id"/>
                <field name="qty" type="measure"/>
            </graph>
        </field>
    </record>
    <record id="view_return_logline_list" model="ir.ui.view">
        <field name="name">cm_sa.return.reason.log.line.list</field>
        <field name="model">cm_sa.return.reason.log.line</field>
        <field name="arch" type="xml">
            <list string="Returned Products" create="false">
                <field name="log_create_date" string="When"/>
                <field name="product_id"/>
                <field name="qty" sum="Total"/>
                <field name="category_id"/>
                <field name="partner_id"/>
            </list>
        </field>
    </record>
    <record id="action_return_log" model="ir.actions.act_window">
        <field name="name">Return Log</field>
        <field name="res_model">cm_sa.return.reason.log</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_return_log_lines" model="ir.actions.act_window">
        <field name="name">By Product (Pivot)</field>
        <field name="res_model">cm_sa.return.reason.log.line</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>
</odoo>
