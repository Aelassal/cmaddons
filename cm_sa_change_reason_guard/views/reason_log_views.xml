<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reason_log_list" model="ir.ui.view">
        <field name="name">cm_sa.reason.log.list</field>
        <field name="model">cm_sa.reason.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="changed_at"/>
                <field name="rule_id"/>
                <field name="res_model"/>
                <field name="res_id"/>
                <field name="changed_field_names"/>
                <field name="category_id"/>
                <field name="user_id"/>
                <field name="res_ref" widget="reference" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_reason_log_form" model="ir.ui.view">
        <field name="name">cm_sa.reason.log.form</field>
        <field name="model">cm_sa.reason.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="changed_at"/>
                            <field name="user_id"/>
                            <field name="rule_id"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="res_ref" widget="reference"/>
                            <field name="changed_field_names"/>
                        </group>
                    </group>
                    <group string="Note">
                        <field name="note" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Values">
                        <group>
                            <field name="old_values_json" readonly="1"/>
                        </group>
                        <group>
                            <field name="new_values_json" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_reason_log_search" model="ir.ui.view">
        <field name="name">cm_sa.reason.log.search</field>
        <field name="model">cm_sa.reason.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="rule_id"/>
                <field name="user_id"/>
                <field name="res_model"/>
                <field name="category_id"/>
                <group>
                    <filter name="group_rule" string="Rule"
                            context="{'group_by': 'rule_id'}"/>
                    <filter name="group_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_reason_log" model="ir.actions.act_window">
        <field name="name">Change Reason Log</field>
        <field name="res_model">cm_sa.reason.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
