<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reason_category_list" model="ir.ui.view">
        <field name="name">cm_sa.reason.category.list</field>
        <field name="model">cm_sa.reason.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_reason_category_form" model="ir.ui.view">
        <field name="name">cm_sa.reason.category.form</field>
        <field name="model">cm_sa.reason.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_reason_category" model="ir.actions.act_window">
        <field name="name">Reason Categories</field>
        <field name="res_model">cm_sa.reason.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
