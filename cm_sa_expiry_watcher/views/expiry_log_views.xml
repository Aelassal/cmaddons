<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_expiry_log_list" model="ir.ui.view">
        <field name="name">cm_sa.expiry.log.list</field>
        <field name="model">cm_sa.expiry.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="triggered_at"/>
                <field name="rule_id"/>
                <field name="res_model"/>
                <field name="record_name"/>
                <field name="expiry_date"/>
                <field name="days_remaining"/>
                <field name="email_sent" widget="boolean_toggle"/>
                <field name="res_ref" widget="reference"/>
            </list>
        </field>
    </record>

    <record id="view_expiry_log_form" model="ir.ui.view">
        <field name="name">cm_sa.expiry.log.form</field>
        <field name="model">cm_sa.expiry.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="triggered_at"/>
                            <field name="rule_id"/>
                            <field name="expiry_date"/>
                            <field name="days_remaining"/>
                        </group>
                        <group>
                            <field name="res_model"/>
                            <field name="record_name"/>
                            <field name="res_ref" widget="reference"/>
                            <field name="email_sent"/>
                        </group>
                    </group>
                    <group string="Notified Users">
                        <field name="notified_user_ids" nolabel="1"
                               widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_expiry_log_search" model="ir.ui.view">
        <field name="name">cm_sa.expiry.log.search</field>
        <field name="model">cm_sa.expiry.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="rule_id"/>
                <field name="res_model"/>
                <field name="record_name"/>
                <filter name="filter_email_sent" string="Email sent"
                        domain="[('email_sent', '=', True)]"/>
                <filter name="filter_email_not_sent" string="Email not sent"
                        domain="[('email_sent', '=', False)]"/>
                <group>
                    <filter name="group_rule" string="Rule"
                            context="{'group_by': 'rule_id'}"/>
                    <filter name="group_model" string="Model"
                            context="{'group_by': 'res_model'}"/>
                    <filter name="group_expiry" string="Expiry Date"
                            context="{'group_by': 'expiry_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_expiry_log" model="ir.actions.act_window">
        <field name="name">Expiry Log</field>
        <field name="res_model">cm_sa.expiry.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
