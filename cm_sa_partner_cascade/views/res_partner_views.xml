<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_cascade" model="ir.ui.view">
        <field name="name">res.partner.form.cascade</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object" name="action_open_cascade_wizard"
                        class="oe_stat_button" icon="fa-sitemap"
                        invisible="not is_company or not child_ids">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Cascade</span>
                        <span class="o_stat_text">to Contacts</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
